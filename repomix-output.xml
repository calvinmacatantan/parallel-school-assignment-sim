"""
    monte_carlo.jl

Orchestration and aggregation for Monte Carlo simulations of the school
assignment lottery.
"""

using Statistics, Printf

"""
    run_monte_carlo(students, schools, n_trials; parallel, seed)
        -> Vector{TrialSummary}

Top-level entry point for running Monte Carlo trials.

# Arguments
- `parallel::Bool = true`: If `true`, dispatch to `run_parallel_mc`; otherwise
  run trials serially in a plain loop.
- `seed::Int = 0`: Base RNG seed.
"""
function run_monte_carlo(
    students::Vector{Student},
    schools::Vector{School},
    n_trials::Int;
    parallel::Bool = true,
    seed::Int = 0,
)::Vector{TrialSummary}
    if parallel
        return run_parallel_mc(students, schools, n_trials; seed = seed)
    else
        return run_serial_mc(students, schools, n_trials; seed = seed)
    end
end

"""
    run_serial_mc(students, schools, n_trials; seed) -> Vector{TrialSummary}

Serial (single-threaded) Monte Carlo loop. Used as baseline and for correctness
comparison against the parallel version.
"""
function run_serial_mc(
    students::Vector{Student},
    schools::Vector{School},
    n_trials::Int;
    seed::Int = 0,
)::Vector{TrialSummary}
    results = Vector{TrialSummary}(undef, n_trials)
    rng = MersenneTwister(seed)
    for i in 1:n_trials
        result = run_serial_with_fresh_lottery(students, schools; rng = rng)
        results[i] = to_trial_summary(result)
    end
    return results
end

"""
    aggregate_results(summaries) -> NamedTuple

Aggregate a vector of `TrialSummary` objects into mean and standard-deviation
statistics across all trials.

# Returns
A `NamedTuple` with fields:
- `mean_first_choice_rate::Float64`
- `std_first_choice_rate::Float64`
- `mean_unassigned::Float64`
- `std_unassigned::Float64`
- `mean_rank_distribution::Vector{Float64}`: Average fraction assigned at each rank.
- `n_trials::Int`
"""
function aggregate_results(summaries::Vector{TrialSummary})
    n = length(summaries)
    @assert n > 0 "No trials to aggregate."

    fc_rates     = [s.first_choice_rate for s in summaries]
    unassigned   = [s.unassigned_count  for s in summaries]
    rank_len     = length(summaries[1].rank_distribution)
    rank_matrix  = hcat([s.rank_distribution for s in summaries]...)  # rank_len × n

    return (
        mean_first_choice_rate = mean(fc_rates),
        std_first_choice_rate  = std(fc_rates),
        mean_unassigned        = mean(unassigned),
        std_unassigned         = std(unassigned),
        mean_rank_distribution = vec(mean(rank_matrix; dims = 2)),
        n_trials               = n,
    )
end

"""
    print_summary(agg)

Pretty-print aggregated Monte Carlo statistics to stdout.
"""
function print_summary(agg)
    println("=" ^ 50)
    println("Monte Carlo Summary  ($(agg.n_trials) trials)")
    println("=" ^ 50)
    @printf "  Mean first-choice rate : %.2f%%  (±%.2f%%)\n" (agg.mean_first_choice_rate * 100) (agg.std_first_choice_rate * 100)
    @printf "  Mean unassigned        : %.1f  (±%.1f)\n" agg.mean_unassigned agg.std_unassigned
    println("  Rank distribution (mean fraction):")
    for (k, frac) in enumerate(agg.mean_rank_distribution)
        @printf "    Rank %d : %.2f%%\n" k frac * 100
    end
    println("=" ^ 50)
end
