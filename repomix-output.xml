"""
    parallel_sim.jl

Multithreaded Monte Carlo simulation using `Threads.@threads`.

Each thread runs independent trials with its own RNG instance to avoid
data races on shared mutable state. Results are written into pre-allocated
per-trial slots so no locking is needed.
"""

using Random

"""
    run_parallel_mc(students, schools, n_trials; seed) -> Vector{TrialSummary}

Run `n_trials` assignment simulations in parallel using Julia's built-in
thread pool (`Threads.@threads`).

Race-condition avoidance strategy
----------------------------------
- Each trial writes into a unique index of a pre-allocated `results` vector.
- Each thread gets its own `MersenneTwister` seeded from `seed + thread_id`
  so RNG state is never shared.
- School capacity counters are local to each trial (not shared across threads).

# Arguments
- `students`: Base student set (preferences fixed; lottery re-drawn each trial).
- `schools`: School definitions (capacity treated as read-only).
- `n_trials`: Number of Monte Carlo replications.
- `seed`: Base seed for reproducibility; thread `t` uses `seed + t`.
"""
function run_parallel_mc(
    students::Vector{Student},
    schools::Vector{School},
    n_trials::Int;
    seed::Int = 0,
)::Vector{TrialSummary}
    results = Vector{TrialSummary}(undef, n_trials)

    # One RNG per trial, seeded deterministically from the base seed.
    # We allocate all RNGs up front to keep the @threads loop allocation-free.
    rngs = [MersenneTwister(seed + i) for i in 1:n_trials]

    Threads.@threads for i in 1:n_trials
        result = run_serial_with_fresh_lottery(students, schools; rng = rngs[i])
        results[i] = to_trial_summary(result)
    end

    return results
end

"""
    to_trial_summary(result::AssignmentResult) -> TrialSummary

Convert a full `AssignmentResult` into the lightweight `TrialSummary` used for
Monte Carlo aggregation.
"""
function to_trial_summary(result::AssignmentResult)::TrialSummary
    n_students = length(result.assignments)
    rank_fracs = result.rank_distribution ./ n_students
    return TrialSummary(
        result.first_choice_rate,
        result.unassigned_count,
        rank_fracs,
    )
end

"""
    run_parallel_scaling(students, schools, n_trials; thread_counts, seed)
        -> Dict{Int, Float64}

Benchmark parallel throughput at different logical thread-count limits.

Because Julia's thread count is fixed at startup, this function simulates
scaling by splitting `n_trials` across `k` chunks and measuring wall time
for each `k` in `thread_counts`.

Returns a Dict mapping thread count -> elapsed seconds.
"""
function run_parallel_scaling(
    students::Vector{Student},
    schools::Vector{School},
    n_trials::Int;
    thread_counts::Vector{Int} = [1, 2, 4, 8],
    seed::Int = 0,
)::Dict{Int,Float64}
    times = Dict{Int,Float64}()
    for k in thread_counts
        chunk = max(1, n_trials ÷ k)
        t0 = time()
        # Run `chunk` trials (simulates one thread's share of work at level k)
        run_parallel_mc(students, schools, chunk; seed = seed)
        elapsed = time() - t0
        times[k] = elapsed
    end
    return times
end
